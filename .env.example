# Your Discord bot token from https://discord.com/developers/applications
# Enable the MESSAGE CONTENT intent under Bot -> Privileged Gateway Intents
# (required for .prefix commands).
DISCORD_TOKEN=your-token-here

# Optional: a server ID for instant slash-command sync while testing.
# Leave empty to sync globally (can take up to an hour to appear).
GUILD_ID=

# Optional: command prefix (default: .)
PREFIX=.

# Optional: PostgreSQL connection string. When set, Postgres is used
# instead of SQLite (Railway provides this from its PostgreSQL service).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: where to store the SQLite database when DATABASE_URL is not
# set (default: economy.db)
DB_PATH=economy.db
